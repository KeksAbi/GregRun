using System.Collections;
using System.Collections.Generic;
using UnityEngine;

public class PlayerCam : MonoBehaviour
{
    public float sensX;
    public float sensY;

    public Transform orientation;

    private Quaternion characterTargetRot;
    private Quaternion cameraTargetRot;

    private void Start()
    {
        Cursor.lockState = CursorLockMode.Locked;
        Cursor.visible = false;

        characterTargetRot = orientation.localRotation;
        cameraTargetRot = transform.localRotation;
    }

    private void Update()
    {
        // Get mouse input
        float yRot = Input.GetAxisRaw("Mouse X") * sensX * Time.deltaTime;
        float xRot = Input.GetAxisRaw("Mouse Y") * sensY * Time.deltaTime;

        // Rotate around Y axis (horizontal)
        characterTargetRot *= Quaternion.Euler(0f, yRot, 0f);

        // Rotate around X axis (vertical)
        cameraTargetRot *= Quaternion.Euler(-xRot, 0f, 0f);

        // Clamp vertical rotation
        cameraTargetRot = ClampRotationAroundXAxis(cameraTargetRot);

        // Apply rotations
        if (orientation != null)
        {
            orientation.localRotation = characterTargetRot;
        }
        transform.localRotation = cameraTargetRot;
    }

    Quaternion ClampRotationAroundXAxis(Quaternion q)
    {
        q.x /= q.w;
        q.y /= q.w;
        q.z /= q.w;
        q.w = 1.0f;

        float angleX = 2.0f * Mathf.Rad2Deg * Mathf.Atan(q.x);
        angleX = Mathf.Clamp(angleX, -90f, 90f);
        q.x = Mathf.Tan(0.5f * Mathf.Deg2Rad * angleX);

        return q;
    }
}
