using UnityEngine;

public class SoundCaller : MonoBehaviour
{
    public static void PlaySound(string gunName, string type, Vector3 position)
    {
        if (string.IsNullOrEmpty(gunName))
        {
            Debug.LogWarning("No weapon name provided!");
            return;
        }

        // Build the path: Resources/Sounds/<gunname>/<gunname>_<type>
        string soundPath = $"Sounds/{gunName}/{gunName}_{type}";

        // Load the audio clip from Resources
        AudioClip soundClip = Resources.Load<AudioClip>(soundPath);

        if (soundClip == null)
        {
            // List all clips found under Sounds/ for debugging
            AudioClip[] allClips = Resources.LoadAll<AudioClip>("Sounds");
            Debug.LogWarning($"Sound not found at path: '{soundPath}' | Total clips in Resources/Sounds: {allClips.Length}");
            foreach (AudioClip c in allClips)
                Debug.Log($"  Found clip: {c.name}");
            return;
        }

        // Play the sound at the specified position
        AudioSource.PlayClipAtPoint(soundClip, position);
    }
}